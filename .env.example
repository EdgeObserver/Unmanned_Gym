# ============================================================================
# Unmanned Gym - Environment Configuration
# 环境变量配置文件
# ============================================================================
# ⚠️ 重要提示: 
# 1. 此文件包含敏感信息，切勿提交到 Git
# 2. 已添加到 .gitignore，确保不会被版本控制
# 3. 复制此文件为 .env.local 并填写真实值
# ============================================================================

# ==================== Database Configuration ====================
# MySQL 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=unmanned_gym
DB_USERNAME=root
DB_PASSWORD=your_mysql_password_here

# ==================== Redis Configuration ====================
# Redis 缓存配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# ==================== RabbitMQ Configuration ====================
# RabbitMQ 消息队列配置
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=your_rabbitmq_password_here
RABBITMQ_VIRTUAL_HOST=/

# ==================== Aliyun OSS Configuration ====================
# 阿里云对象存储配置
OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
OSS_BUCKET_NAME=your-bucket-name
ALIYUN_ACCESS_KEY_ID=your-access-key-id-here
ALIYUN_ACCESS_KEY_SECRET=your-access-key-secret-here
OSS_DIR_PREFIX=user_face/
OSS_ILLEGAL_DIR_PREFIX=illegal_user_face/
OSS_LOCAL_BASE=D:/IdeaProjects/AttendanceSystem/data/face_cache

# ==================== Nacos Configuration ====================
# Nacos 服务注册与配置中心
NACOS_SERVER_ADDR=localhost:8848
NACOS_NAMESPACE=
NACOS_USERNAME=nacos
NACOS_PASSWORD=nacos

# ==================== Application Configuration ====================
# 应用基础配置
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev

# ==================== Face Recognition Service ====================
# 人脸识别服务配置
FACE_SERVICE_PORT=5000
FACE_SERVICE_URL=http://localhost:5000
FACE_PYTHON_SCRIPT_PATH=D:/IdeaProjects/AttendanceSystem/python/FaceService.py
FACE_CAMERA_ENABLED=true
FACE_CAMERA_DEVICE_ID=0

# ==================== Python AI Services ====================
# Python AI 服务配置
PERSON_DETECT_SERVICE_URL=http://localhost:5001
QUERY_SERVICE_URL=http://localhost:5002
DEEPSEEK_API_KEY=your-deepseek-api-key-here
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-neo4j-password-here

# ==================== JWT Configuration ====================
# JWT 令牌配置
JWT_SECRET=your-jwt-secret-key-here-must-be-at-least-32-characters
JWT_EXPIRATION=86400000

# ==================== File Upload Configuration ====================
# 文件上传配置
MAX_FILE_SIZE=10MB
MAX_REQUEST_SIZE=10MB
UPLOAD_PATH=D:/IdeaProjects/AttendanceSystem/uploads

# ==================== Email Configuration (Optional) ====================
# 邮件服务配置（可选）
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USERNAME=your-email@example.com
EMAIL_PASSWORD=your-email-password
EMAIL_FROM=noreply@example.com

# ==================== Logging Configuration ====================
# 日志配置
LOG_LEVEL=INFO
LOG_PATH=./logs
LOG_MAX_SIZE=10MB
LOG_MAX_HISTORY=30
